{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ESNext",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/renderer/src/*"
            ]
        }
    },
    "include": [
        "src/renderer/src/**/*",
        "src/renderer/*.d.ts",
        "src/preload/index.d.ts"
    ]
}